import java.util.Arrays;

class Solution {
    public int findContentChildren(int[] g, int[] s) {
        // Sort both arrays to use a greedy approach
        Arrays.sort(g);
        Arrays.sort(s);
        
        int childIndex = 0;
        int cookieIndex = 0;
        
        // Iterate through cookies to satisfy children
        while (childIndex < g.length && cookieIndex < s.length) {
            // If current cookie can satisfy the current child
            if (s[cookieIndex] >= g[childIndex]) {
                childIndex++; // Move to the next child
            }
            cookieIndex++; // Always move to the next larger cookie
        }
        
        return childIndex; // Total satisfied children
    }
}
